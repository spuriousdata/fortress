#!/bin/sh

# Any of these can be overridden in /usr/local/etc/fortress/$jailname.conf

RELEASE=15.0-RELEASE
DATASET=zroot/fortress
MOUNTPOINT=/fortress
NETWORKING=jib
#PUBLIC_IFACE="jailiface otheriface"
PUBLIC_IFACE=jailiface


{{JIB}}

# Tell jib to use this specific bridge. Leave blank if you don't know what that means. 
JIB_BRIDGE=

# diable warnings
#NOWARN=1

# Automatically regenerate the fstab and jail.conf file when starting the jail
AUTOGEN=1

DOMAIN=jails.example.org

# add prestart/poststop commands to jail.conf -- MUST end with semicolon ';'
# These will always get added, even if using jib
JAIL_PRESTART=
JAIL_POSTSTOP=

# if NETWORKING is unset, then run these in exec.prestart/exec.poststop
# These will ONLY run if not using jib
NET_PRESTART=
NET_POSTSTOP=


#RESOLV_CONF=$(cat <<EOM
#nameserver 192.168.12.1
#EOM
#)

## The interface name inside the jail will always be e0b_$jailname
## DO NOT QUOTE YOUR VAULES
#RC_CONF=$(cat <<EOM
#ifconfig_e0b_test=inet 192.168.12.129/24
#defaultrouter=192.168.12.1
#EOM
#)

## DO NOT CHANGE THIS 
##  unless you really know what you're doing
MOUNT=$(cat <<EOM
bin
boot
lib
libexec
rescue
sbin
etcupdate
usr/bin
usr/include
usr/lib
usr/libexec
usr/sbin
usr/share
usr/src
usr/libdata
usr/lib32
EOM
)
